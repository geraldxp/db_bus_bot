BOT_TOKEN=your_telegram_bot_token_here
DATABASE_URL=postgresql://user:password@localhost:5432/dbbus
ADMIN_CHANNEL_ID=-100xxxxxxxxx
SUPPORT_GROUP_ID=-100xxxxxxxxx
ADMIN_USERNAME=youradmin_handle
DEPOSIT_ADDRESS=YourSolanaWalletAddressHere

# Helius RPC — required for automatic payment/deposit confirmation
# Get a free key at https://helius.dev
HELIUS_API_KEY=your_helius_api_key_here

# Telegram WebApp URL for wallet connect mini-app (optional but recommended)
# Must be publicly accessible HTTPS. Leave blank to use text-based fallback only.
# Example: https://yourdomain.com/wallet  (served by webapp/server.py)
WEBAPP_URL=

# Optional
DEPOSIT_EXPIRY_MINUTES=60
PAYMENT_EXPIRY_MINUTES=30
WATCHER_INTERVAL=30
